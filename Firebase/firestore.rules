rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function existsUser(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userData(uid) {
      return userDoc(uid).data;
    }

    function currentUserData() {
      return userData(request.auth.uid);
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwner() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && ('globalRole' in currentUserData())
        && currentUserData().globalRole == 'owner';
    }

    function isActiveUser() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && (
          !('accountStatus' in currentUserData())
          || currentUserData().accountStatus == 'active'
          || currentUserData().accountStatus == 'warned'
        )
        && (
          !('blockState' in currentUserData())
          || currentUserData().blockState == 'active'
          || currentUserData().blockState == 'warned'
        );
    }

    function canModerateSection(section) {
      return section is string && isOwner();
    }

    function canManageGuide() {
      return isOwner()
        || (isSignedIn()
          && existsUser(request.auth.uid)
          && ('canManageGuide' in currentUserData())
          && currentUserData().canManageGuide == true);
    }

    function isApprovedContent() {
      return resource.data.moderationStatus == 'approved';
    }

    function userSelfEditableFields() {
      return ['fullName', 'displayName', 'telegramUsername', 'city', 'bio', 'email', 'selectedFederalState', 'avatarURL', 'updatedAt'];
    }

    function recentViewFields() {
      return ['itemId', 'itemType', 'title', 'subtitle', 'imageURL', 'viewedAt'];
    }

    function activityLogFields() {
      return ['id', 'actionType', 'targetId', 'targetType', 'title', 'subtitle', 'imageURL', 'createdAt'];
    }

    function safeRecentViewWrite(uid, recentViewId) {
      return isActiveUser()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(recentViewFields())
        && request.resource.data.itemId is string
        && request.resource.data.itemType in ['news', 'event', 'organization', 'guide']
        && request.resource.data.title is string
        && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string || request.resource.data.subtitle == null)
        && (!('imageURL' in request.resource.data) || request.resource.data.imageURL is string || request.resource.data.imageURL == null)
        && request.resource.data.viewedAt is timestamp
        && recentViewId == request.resource.data.itemType + '_' + request.resource.data.itemId;
    }

    function safeActivityLogWrite(uid, activityLogId) {
      return isActiveUser()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(activityLogFields())
        && request.resource.data.id == activityLogId
        && request.resource.data.actionType in [
          'registeredForEvent',
          'canceledEventRegistration',
          'followedOrganization',
          'unfollowedOrganization',
          'savedNews',
          'unsavedNews',
          'savedEvent',
          'unsavedEvent',
          'savedOrganization',
          'unsavedOrganization'
        ]
        && request.resource.data.targetId is string
        && request.resource.data.targetType in ['news', 'event', 'organization']
        && request.resource.data.title is string
        && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string || request.resource.data.subtitle == null)
        && (!('imageURL' in request.resource.data) || request.resource.data.imageURL is string || request.resource.data.imageURL == null)
        && request.resource.data.createdAt is timestamp;
    }

    function safeUserCreate(uid) {
      return isSelf(uid)
        && request.resource.data.id == uid
        && request.resource.data.fullName is string
        && request.resource.data.displayName is string
        && request.resource.data.city is string
        && request.resource.data.email is string
        && request.resource.data.bio is string
        && !('role' in request.resource.data)
        && !('moderatorSections' in request.resource.data)
        && request.resource.data.isBlocked == false
        && request.resource.data.blockState == 'active'
        && request.resource.data.globalRole == 'user'
        && request.resource.data.canManageGuide == false
        && request.resource.data.selectedFederalState is string
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.warningCount == 0
        && request.resource.data.acceptedTermsAt is timestamp
        && request.resource.data.acceptedPrivacyAt is timestamp
        && request.resource.data.termsVersion is string
        && request.resource.data.privacyVersion is string
        && request.resource.data.communityMemberships is list
        && request.resource.data.communityMemberships.size() == 0;
    }

    function safeSelfUserUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfEditableFields());
    }

    function ownerUserEditableFields() {
      return ['accountStatus', 'blockState', 'warningCount', 'updatedAt', 'isBlocked', 'banExpiresAt'];
    }

    function safeOwnerUserUpdate(uid) {
      return isOwner()
        && request.resource.data.id == resource.data.id
        && ('globalRole' in resource.data)
        && request.resource.data.globalRole == resource.data.globalRole
        && (!('role' in resource.data) || request.resource.data.role == resource.data.role)
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!('communityMemberships' in resource.data) || request.resource.data.communityMemberships == resource.data.communityMemberships)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerUserEditableFields());
    }

    function canWriteContent(section) {
      return canModerateSection(section);
    }

    function canModerateAppContent(section) {
      return canModerateSection(section);
    }

    function hasOrganizationRole(organizationId, role) {
      return isSignedIn()
        && organizationId is string
        && (
          (
            role == 'communityOwner'
            && ('ownerId' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.ownerId == request.auth.uid
          )
          || (
            role == 'communityAdmin'
            && ('adminIds' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.adminIds.hasAny([request.auth.uid])
          )
          || (
            role == 'communityModerator'
            && ('moderatorIds' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.moderatorIds.hasAny([request.auth.uid])
          )
        );
    }

    function isOrganizationOwner(organizationId) {
      return hasOrganizationRole(organizationId, 'communityOwner');
    }

    function isOrganizationAdmin(organizationId) {
      return hasOrganizationRole(organizationId, 'communityAdmin');
    }

    function isOrganizationModerator(organizationId) {
      return hasOrganizationRole(organizationId, 'communityModerator');
    }

    function canEditOrganizationContent(organizationId) {
      return isOrganizationOwner(organizationId)
        || isOrganizationAdmin(organizationId)
        || isOrganizationModerator(organizationId);
    }

    function canManageOrganizationPhotos(organizationId) {
      return isOwner() || canEditOrganizationContent(organizationId);
    }

    function canReadOrganizationByLookup(organizationId) {
      return exists(/databases/$(database)/documents/organizations/$(organizationId))
        && (
          get(/databases/$(database)/documents/organizations/$(organizationId)).data.moderationStatus == 'approved'
          || isOwner()
          || canEditOrganizationContent(organizationId)
        );
    }

    function canReadOrganization(organizationId) {
      return (('moderationStatus' in resource.data) && resource.data.moderationStatus == 'approved')
        || canReadOrganizationByLookup(organizationId);
    }

    function organizationPhotoFields() {
      return ['id', 'organizationId', 'imageURL', 'caption', 'uploadedBy', 'createdAt', 'updatedAt'];
    }

    function safeOrganizationPhotoCreate(organizationId, photoId) {
      return canManageOrganizationPhotos(organizationId)
        && request.resource.data.keys().hasOnly(organizationPhotoFields())
        && request.resource.data.id == photoId
        && request.resource.data.organizationId == organizationId
        && request.resource.data.imageURL is string
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && (!('caption' in request.resource.data) || request.resource.data.caption is string || request.resource.data.caption == null)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp || request.resource.data.updatedAt == null);
    }

    function canModerateOrganizationContent(organizationId) {
      return isOrganizationOwner(organizationId)
        || isOrganizationAdmin(organizationId)
        || isOrganizationModerator(organizationId);
    }

    function canEditOrganizationInfo(organizationId) {
      return isOwner() || isOrganizationOwner(organizationId) || isOrganizationAdmin(organizationId);
    }

    function canManageOrganizationRoles(organizationId) {
      return isOwner() || isOrganizationOwner(organizationId);
    }

    function organizationRoleFields() {
      return ['ownerId', 'adminIds', 'moderatorIds', 'updatedAt'];
    }

    // TODO: Move organization membership storage out of users.communityMemberships
    // into organizationMemberships/{organizationId_userId} or
    // organizations/{organizationId}/members/{userId}. Until then, organizations
    // ownerId/adminIds/moderatorIds are the writable role source of truth.
    function safeOrganizationRoleUpdate(organizationId) {
      return canManageOrganizationRoles(organizationId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(organizationRoleFields())
        && (!('ownerId' in resource.data) || ('ownerId' in request.resource.data))
        && (!('ownerId' in request.resource.data) || request.resource.data.ownerId is string)
        && (isOwner() || request.resource.data.ownerId == resource.data.ownerId);
    }

    function safeOrganizationRoleAuditCreate() {
      return isActiveUser()
        && request.resource.data.actionType in ['organizationRoleAssigned', 'organizationRoleRemoved']
        && request.resource.data.previousValue is map
        && request.resource.data.newValue is map
        && ('organizationId' in request.resource.data.previousValue)
        && ('organizationId' in request.resource.data.newValue)
        && ('role' in request.resource.data.previousValue)
        && ('role' in request.resource.data.newValue)
        && request.resource.data.previousValue.organizationId == request.resource.data.newValue.organizationId
        && canManageOrganizationRoles(request.resource.data.previousValue.organizationId)
        && (
          isOwner()
          || (
            request.resource.data.previousValue.role in ['none', 'communityAdmin', 'communityModerator']
            && request.resource.data.newValue.role in ['none', 'communityAdmin', 'communityModerator']
          )
        );
    }

    function organizationSafeInfoFields() {
      return [
        'name',
        'description',
        'shortDescription',
        'fullDescription',
        'imageURL',
        'logoURL',
        'coverURL',
        'contactEmail',
        'website',
        'email',
        'phone',
        'address',
        'latitude',
        'longitude',
        'city',
        'federalState',
        'organizationType',
        'foundedYear',
        'foundedMonth',
        'languages',
        'socialLinks',
        'telegramURL',
        'donationURL',
        'missionStatement',
        'contactPerson',
        'updatedAt'
      ];
    }

    function safeOrganizationInfoUpdate(organizationId) {
      return canEditOrganizationInfo(organizationId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(organizationSafeInfoFields());
    }

    function ownDocumentRead() {
      return isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    function ownLikeDocumentRead(likeId) {
      return isActiveUser()
        && likeId.matches('^.+_' + request.auth.uid + '$');
    }

    function ownDocumentCreate() {
      return isActiveUser()
        && request.resource.data.userId == request.auth.uid;
    }

    function ownDocumentDelete() {
      return isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    function isOrganizationContent(data) {
      return ('sourceType' in data)
        && data.sourceType == 'organization'
        && ('organizationId' in data)
        && data.organizationId is string
        && data.organizationId.size() > 0;
    }

    function canCreateOrganizationContent() {
      return isOrganizationContent(request.resource.data)
        && (isOwner() || canEditOrganizationContent(request.resource.data.organizationId));
    }

    function canUpdateOrganizationContent() {
      return isOrganizationContent(resource.data)
        && isOrganizationContent(request.resource.data)
        && request.resource.data.sourceType == resource.data.sourceType
        && request.resource.data.organizationId == resource.data.organizationId
        && (isOwner() || canEditOrganizationContent(resource.data.organizationId));
    }

    function canDeleteOrganizationContent() {
      return isOrganizationContent(resource.data)
        && isOrganizationOwner(resource.data.organizationId);
    }

    function canModerateNewsComment(newsId) {
      return canModerateAppContent('news')
        || canModerateSection('comments')
        || (
          get(/databases/$(database)/documents/news/$(newsId)).data.sourceType == 'organization'
          && canModerateOrganizationContent(get(/databases/$(database)/documents/news/$(newsId)).data.organizationId)
        );
    }

    function canModerateEventComment(eventId) {
      return canModerateAppContent('events')
        || canModerateSection('comments')
        || (
          get(/databases/$(database)/documents/events/$(eventId)).data.sourceType == 'organization'
          && canModerateOrganizationContent(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId)
        );
    }

    function isAppManagedHeroBannerDocument(bannerId) {
      return bannerId == 'homeBanner'
        || bannerId == 'eventsBanner'
        || bannerId == 'organizationsBanner'
        || bannerId == 'guideBanner';
    }

    function canReadModerationQueue(section) {
      return canModerateSection(section);
    }

    function canReadOrganizationModerationQueue(data) {
      return isOrganizationContent(data)
        && canModerateOrganizationContent(data.organizationId)
        && (
          data.moderationStatus == 'pendingReview'
          || data.moderationStatus == 'rejected'
          || data.moderationStatus == 'archived'
        );
    }

    function onlySubscriberCountChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscriberCount'])
        && request.resource.data.subscriberCount is int
        && request.resource.data.subscriberCount >= 0;
    }

    function onlyModerationStatusChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['moderationStatus']);
    }

    // TODO: Replace direct client counter writes with server-side aggregation or sharded counters.
    function onlyNewsEngagementCountersChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']);
    }

    function onlyNewsViewCountIncremented() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;
    }

    function onlyNewsCommentCountChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
        && (
          (!('commentCount' in resource.data) && request.resource.data.commentCount == 1)
          || (('commentCount' in resource.data)
            && (request.resource.data.commentCount == resource.data.commentCount + 1
              || (resource.data.commentCount > 0 && request.resource.data.commentCount == resource.data.commentCount - 1)))
        );
    }

    // TODO: Replace direct client counter writes with server-side aggregation or sharded counters.
    function onlyEventCountersChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'registeredCount']);
    }

    function onlyEventViewCountIncremented() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;
    }

    function onlyEventCommentCountChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
        && (
          (!('commentCount' in resource.data) && request.resource.data.commentCount == 1)
          || (('commentCount' in resource.data)
            && (request.resource.data.commentCount == resource.data.commentCount + 1
              || (resource.data.commentCount > 0 && request.resource.data.commentCount == resource.data.commentCount - 1)))
        );
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isOwner();

      allow create: if safeUserCreate(uid);

      allow update: if safeOwnerUserUpdate(uid)
        || safeSelfUserUpdate(uid);

      allow delete: if isOwner() && uid != request.auth.uid;

      match /newsBookmarks/{newsId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == newsId
          && request.resource.data.newsId == newsId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.newsId == newsId
          && resource.data.userId == uid;
      }

      match /eventBookmarks/{eventId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == eventId
          && request.resource.data.eventId == eventId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.eventId == eventId
          && resource.data.userId == uid;
      }

      match /organizationBookmarks/{organizationId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == organizationId
          && request.resource.data.organizationId == organizationId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.organizationId == organizationId
          && resource.data.userId == uid;
      }

      match /eventViews/{eventId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == eventId
          && request.resource.data.eventId == eventId
          && request.resource.data.userId == uid;

        allow update, delete: if false;
      }

      match /newsViews/{newsId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == newsId
          && request.resource.data.newsId == newsId
          && request.resource.data.userId == uid;

        allow update, delete: if false;
      }

      match /recentViews/{recentViewId} {
        allow read: if isSelf(uid);

        allow create, update: if safeRecentViewWrite(uid, recentViewId);

        allow delete: if isActiveUser()
          && request.auth.uid == uid;
      }

      match /activityLog/{activityLogId} {
        allow read: if isSelf(uid);

        allow create: if safeActivityLogWrite(uid, activityLogId);

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid;
      }
    }

    match /news/{newsId} {
      allow read: if isApprovedContent()
        || canReadModerationQueue('news')
        || canReadOrganizationModerationQueue(resource.data);
      allow create: if canCreateOrganizationContent();
      allow delete: if canWriteContent('news') || canDeleteOrganizationContent();
      allow update: if canUpdateOrganizationContent()
        || (
          isOrganizationContent(resource.data)
          && canModerateOrganizationContent(resource.data.organizationId)
          && onlyModerationStatusChanged()
        )
        || (isActiveUser() && (onlyNewsEngagementCountersChanged() || onlyNewsViewCountIncremented() || onlyNewsCommentCountChanged()));

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/news/$(newsId)).data.moderationStatus == 'approved'
          || canReadModerationQueue('news');

        allow create: if isActiveUser()
          && request.resource.data.id == commentId
          && request.resource.data.parentType == 'news'
          && request.resource.data.parentId == newsId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt is timestamp
          && request.resource.data.isDeleted == false;

        allow update: if isActiveUser()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.parentType == resource.data.parentType
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'body', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow delete: if (isActiveUser() && resource.data.authorId == request.auth.uid)
          || canModerateNewsComment(newsId);
      }
    }

    match /events/{eventId} {
      allow read: if isApprovedContent()
        || canReadModerationQueue('events')
        || canReadOrganizationModerationQueue(resource.data);
      allow create: if isOwner() || canCreateOrganizationContent();
      allow delete: if isOwner() || canDeleteOrganizationContent();
      allow update: if isOwner()
        || canUpdateOrganizationContent()
        || (canModerateSection('events') && onlyModerationStatusChanged())
        || (
          isOrganizationContent(resource.data)
          && canModerateOrganizationContent(resource.data.organizationId)
          && onlyModerationStatusChanged()
        )
        || (isActiveUser() && (onlyEventCountersChanged() || onlyEventViewCountIncremented() || onlyEventCommentCountChanged()));

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/events/$(eventId)).data.moderationStatus == 'approved'
          || canReadModerationQueue('events');

        allow create: if isActiveUser()
          && request.resource.data.id == commentId
          && request.resource.data.parentType == 'event'
          && request.resource.data.parentId == eventId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt is timestamp
          && request.resource.data.isDeleted == false;

        allow update: if isActiveUser()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.parentType == resource.data.parentType
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'body', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow delete: if (isActiveUser() && resource.data.authorId == request.auth.uid)
          || canModerateEventComment(eventId);
      }
    }

    match /organizations/{organizationId} {
      allow read: if canReadOrganization(organizationId);
      allow create: if isOwner();
      allow delete: if isOwner();
      allow update: if isOwner()
        || safeOrganizationRoleUpdate(organizationId)
        || safeOrganizationInfoUpdate(organizationId)
        || (canModerateSection('organizations') && onlyModerationStatusChanged())
        || (isActiveUser() && onlySubscriberCountChanged());

      match /photos/{photoId} {
        allow read: if canReadOrganization(organizationId);
        allow create: if safeOrganizationPhotoCreate(organizationId, photoId);
        allow update: if false;
        allow delete: if canManageOrganizationPhotos(organizationId)
          && resource.data.organizationId == organizationId;
      }
    }

    match /likes/{likeId} {
      allow read: if ownDocumentRead()
        || ownLikeDocumentRead(likeId)
        || isOwner();

      allow create: if ownDocumentCreate();

      allow update: if false;

      allow delete: if ownDocumentDelete()
        || isOwner();
    }

    match /registrations/{registrationId} {
      allow read: if ownDocumentRead()
        || isOwner();

      allow create: if ownDocumentCreate();

      allow update: if false;

      allow delete: if ownDocumentDelete()
        || isOwner();
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open';

      allow update, delete: if isOwner();
    }

    match /auditLogs/{auditLogId} {
      allow read: if isOwner();

      allow create: if (isOwner() || safeOrganizationRoleAuditCreate())
        && request.resource.data.actionType in [
          'warningIssued',
          'suspended',
          'banned',
          'unblocked',
          'deactivated',
          'organizationRoleAssigned',
          'organizationRoleRemoved'
        ]
        && request.resource.data.targetUserId is string
        && request.resource.data.performedBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.reason is string
        && request.resource.data.previousValue is map
        && request.resource.data.newValue is map;

      allow update, delete: if false;
    }

    match /appConfig/{bannerId} {
      allow read: if isAppManagedHeroBannerDocument(bannerId);
      allow create, update, delete: if isAppManagedHeroBannerDocument(bannerId)
        && isOwner();
    }

    match /guideArticles/{articleId} {
      allow read: if resource.data.moderationStatus == 'approved'
        || canManageGuide();

      allow create, update, delete: if canManageGuide();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
