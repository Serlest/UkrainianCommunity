rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function existsUser(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userData(uid) {
      return userDoc(uid).data;
    }

    function currentUserData() {
      return userData(request.auth.uid);
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isActiveUser() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && (
          !('accountStatus' in currentUserData())
          || currentUserData().accountStatus == 'active'
          || currentUserData().accountStatus == 'warned'
        )
        && (
          !('blockState' in currentUserData())
          || currentUserData().blockState == 'active'
          || currentUserData().blockState == 'warned'
        );
    }

    function isAppOwner() {
      return isActiveUser()
        && ('globalRole' in currentUserData())
        && currentUserData().globalRole == 'owner';
    }

    function isAppAdmin() {
      return isActiveUser()
        && ('globalRole' in currentUserData())
        && currentUserData().globalRole == 'admin';
    }

    function isAppModerator() {
      return isActiveUser()
        && ('globalRole' in currentUserData())
        && currentUserData().globalRole == 'moderator';
    }

    function isPlatformModeratorTier() {
      return isAppOwner() || isAppAdmin() || isAppModerator();
    }

    function isGuideEditor() {
      return isActiveUser()
        && (
          isAppOwner()
          || (('canManageGuide' in currentUserData()) && currentUserData().canManageGuide == true)
        );
    }

    function canManageGuide() {
      return isGuideEditor();
    }

    function canManageFeedback() {
      return isPlatformModeratorTier();
    }

    function canManageReports() {
      return isPlatformModeratorTier();
    }

    function canManageOrganizationRequests() {
      return isAppOwner() || isAppAdmin();
    }

    function canManageFeaturedBanners() {
      return isAppOwner();
    }

    function canUseOrganizationOverride() {
      return isAppOwner();
    }

    function isOwner() {
      return isAppOwner();
    }

    function canModerateSection(section) {
      // topAdmin, appModerator, and moderatorSections are migration-only and
      // are not active authorization sources.
      return section is string && isPlatformModeratorTier();
    }

    function guideArticleRequiredCreateFields() {
      return [
        'id',
        'title',
        'summary',
        'body',
        'category',
        'regionScope',
        'isPinned',
        'moderationStatus',
        'createdAt',
        'updatedAt',
        'status',
        'createdBy'
      ];
    }

    function guideArticleAllowedFields() {
      return [
        'id',
        'title',
        'summary',
        'body',
        'category',
        'regionScope',
        'federalState',
        'city',
        'officialSourceURL',
        'sourceName',
        'isPinned',
        'moderationStatus',
        'createdAt',
        'updatedAt',
        'contentType',
        'status',
        'contentBlocks',
        'audience',
        'sourceLinks',
        'officialSourcesRequired',
        'priority',
        'isFeatured',
        'createdBy',
        'updatedBy',
        'reviewedBy',
        'publishedAt',
        'lastReviewedAt',
        'nextReviewAt',
        'reviewInterval',
        'archivedAt'
      ];
    }

    function guideArticleEditableFields() {
      return [
        'title',
        'summary',
        'body',
        'category',
        'regionScope',
        'federalState',
        'city',
        'officialSourceURL',
        'sourceName',
        'contentType',
        'contentBlocks',
        'audience',
        'sourceLinks',
        'officialSourcesRequired',
        'priority',
        'isFeatured',
        'reviewInterval',
        'updatedAt',
        'updatedBy'
      ];
    }

    function guideWorkflowFieldsAreEmptyOnCreate() {
      return (!('updatedBy' in request.resource.data) || request.resource.data.updatedBy == null)
        && (!('reviewedBy' in request.resource.data) || request.resource.data.reviewedBy == null)
        && (!('publishedAt' in request.resource.data) || request.resource.data.publishedAt == null)
        && (!('lastReviewedAt' in request.resource.data) || request.resource.data.lastReviewedAt == null)
        && (!('nextReviewAt' in request.resource.data) || request.resource.data.nextReviewAt == null)
        && (!('archivedAt' in request.resource.data) || request.resource.data.archivedAt == null);
    }

    function guideArticleIdentityFieldsArePreserved() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    function guideArticleWorkflowFieldsArePreserved() {
      return request.resource.data.moderationStatus == resource.data.moderationStatus
        && request.resource.data.status == resource.data.status
        && request.resource.data.isPinned == resource.data.isPinned
        && request.resource.data.reviewedBy == resource.data.reviewedBy
        && request.resource.data.publishedAt == resource.data.publishedAt
        && request.resource.data.lastReviewedAt == resource.data.lastReviewedAt
        && request.resource.data.nextReviewAt == resource.data.nextReviewAt
        && request.resource.data.archivedAt == resource.data.archivedAt;
    }

    function guideArticleIsEditableManagedContent() {
      return (!('archivedAt' in resource.data) || resource.data.archivedAt == null)
        && (
          (
            resource.data.moderationStatus == 'draft'
            && (
              !('status' in resource.data)
              || resource.data.status == null
              || resource.data.status == 'draft'
            )
          )
          || (
            resource.data.moderationStatus == 'approved'
            && resource.data.status == 'published'
          )
        );
    }

    function validGuideArticleCreate(articleId) {
      return canManageGuide()
        && request.resource.data.keys().hasAll(guideArticleRequiredCreateFields())
        && request.resource.data.keys().hasOnly(guideArticleAllowedFields())
        && request.resource.data.id == articleId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.moderationStatus == 'draft'
        && request.resource.data.status == 'draft'
        && request.resource.data.isPinned == false
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && guideWorkflowFieldsAreEmptyOnCreate();
    }

    function validGuideArticleEditUpdate() {
      return canManageGuide()
        && guideArticleIsEditableManagedContent()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(guideArticleEditableFields())
        && guideArticleIdentityFieldsArePreserved()
        && guideArticleWorkflowFieldsArePreserved()
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt is timestamp;
    }

    function isPublishedGuideV2Resource() {
      return resource.data.moderationStatus == 'approved'
        && (('publishedAt' in resource.data) && resource.data.publishedAt is timestamp)
        && (!('archivedAt' in resource.data) || resource.data.archivedAt == null);
    }

    function guideNodeAllowedFields() {
      return [
        'id',
        'parentID',
        'category',
        'kind',
        'title',
        'summary',
        'sortOrder',
        'regionScope',
        'federalState',
        'healthStatus',
        'moderationStatus',
        'publishedAt',
        'createdAt',
        'updatedAt',
        'createdBy',
        'updatedBy',
        'archivedAt'
      ];
    }

    function guideMaterialAllowedFields() {
      return [
        'id',
        'kind',
        'category',
        'nodeID',
        'nodePath',
        'title',
        'summary',
        'body',
        'sortOrder',
        'contentBlocks',
        'sourceLinks',
        'officialSourceURL',
        'sourceName',
        'officialSourcesRequired',
        'regionScope',
        'federalState',
        'reviewInterval',
        'lastReviewedAt',
        'nextReviewAt',
        'reviewedBy',
        'healthStatus',
        'moderationStatus',
        'publishedAt',
        'createdAt',
        'updatedAt',
        'createdBy',
        'updatedBy',
        'archivedAt'
      ];
    }

    function hasOptionalGuideV2Timestamps(data) {
      return (!('publishedAt' in data) || data.publishedAt == null || data.publishedAt is timestamp)
        && (!('archivedAt' in data) || data.archivedAt == null || data.archivedAt is timestamp)
        && (!('lastReviewedAt' in data) || data.lastReviewedAt == null || data.lastReviewedAt is timestamp)
        && (!('nextReviewAt' in data) || data.nextReviewAt == null || data.nextReviewAt is timestamp);
    }

    function validGuideNodeWrite(nodeId) {
      return canManageGuide()
        && request.resource.data.keys().hasAll([
          'id',
          'parentID',
          'category',
          'kind',
          'title',
          'sortOrder',
          'moderationStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly(guideNodeAllowedFields())
        && request.resource.data.id == nodeId
        && request.resource.data.parentID is string
        && request.resource.data.category is string
        && request.resource.data.kind in ['section', 'folder']
        && request.resource.data.title is string
        && (!('summary' in request.resource.data) || request.resource.data.summary is string)
        && request.resource.data.sortOrder is number
        && request.resource.data.moderationStatus is string
        && (!('healthStatus' in request.resource.data) || request.resource.data.healthStatus is string)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == null || request.resource.data.createdBy is string)
        && (!('updatedBy' in request.resource.data) || request.resource.data.updatedBy == null || request.resource.data.updatedBy is string)
        && (!('regionScope' in request.resource.data) || request.resource.data.regionScope == null || request.resource.data.regionScope is string)
        && (!('federalState' in request.resource.data) || request.resource.data.federalState == null || request.resource.data.federalState is string)
        && hasOptionalGuideV2Timestamps(request.resource.data);
    }

    function validGuideMaterialWrite(materialId) {
      return canManageGuide()
        && request.resource.data.keys().hasAll([
          'id',
          'kind',
          'category',
          'nodeID',
          'title',
          'sortOrder',
          'moderationStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly(guideMaterialAllowedFields())
        && request.resource.data.id == materialId
        && request.resource.data.kind in ['page', 'catalog']
        && request.resource.data.category is string
        && request.resource.data.nodeID is string
        && (!('nodePath' in request.resource.data) || request.resource.data.nodePath is map)
        && request.resource.data.title is string
        && (!('summary' in request.resource.data) || request.resource.data.summary is string)
        && (!('body' in request.resource.data) || request.resource.data.body is string)
        && request.resource.data.sortOrder is number
        && request.resource.data.moderationStatus is string
        && (!('healthStatus' in request.resource.data) || request.resource.data.healthStatus is string)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == null || request.resource.data.createdBy is string)
        && (!('updatedBy' in request.resource.data) || request.resource.data.updatedBy == null || request.resource.data.updatedBy is string)
        && (!('reviewedBy' in request.resource.data) || request.resource.data.reviewedBy == null || request.resource.data.reviewedBy is string)
        && (!('officialSourceURL' in request.resource.data) || request.resource.data.officialSourceURL == null || request.resource.data.officialSourceURL is string)
        && (!('sourceName' in request.resource.data) || request.resource.data.sourceName == null || request.resource.data.sourceName is string)
        && (!('officialSourcesRequired' in request.resource.data) || request.resource.data.officialSourcesRequired is bool)
        && (!('regionScope' in request.resource.data) || request.resource.data.regionScope == null || request.resource.data.regionScope is string)
        && (!('federalState' in request.resource.data) || request.resource.data.federalState == null || request.resource.data.federalState is string)
        && (!('reviewInterval' in request.resource.data) || request.resource.data.reviewInterval == null || request.resource.data.reviewInterval is string)
        && hasOptionalGuideV2Timestamps(request.resource.data);
    }

    function isApprovedContent() {
      return resource.data.moderationStatus == 'approved';
    }

    function userSelfEditableFields() {
      return ['fullName', 'displayName', 'telegramUsername', 'city', 'bio', 'email', 'selectedFederalState', 'avatarURL', 'updatedAt'];
    }

    function isLegalDocumentType(documentType) {
      return documentType in ['terms', 'privacy'];
    }

    function legalDocumentPointerFields() {
      return [
        'documentType',
        'activeVersion',
        'versionNumber',
        'status',
        'requiresAcceptance',
        'defaultLocale',
        'updatedAt',
        'updatedBy',
        'publishedAt',
        'publishedBy',
        'changeSummary'
      ];
    }

    function legalDocumentVersionFields() {
      return [
        'documentType',
        'version',
        'versionNumber',
        'status',
        'requiresAcceptance',
        'defaultLocale',
        'canonicalLocale',
        'locales',
        'contentHash',
        'changeSummary',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'publishedAt',
        'publishedBy',
        'supersedesVersion'
      ];
    }

    function validLegalDocumentPointer(documentType) {
      return isLegalDocumentType(documentType)
        && request.resource.data.keys().hasOnly(legalDocumentPointerFields())
        && request.resource.data.documentType == documentType
        && request.resource.data.activeVersion is string
        && request.resource.data.versionNumber is int
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.requiresAcceptance is bool
        && request.resource.data.defaultLocale is string
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid
        && (!('publishedAt' in request.resource.data)
          || request.resource.data.publishedAt == null
          || request.resource.data.publishedAt is timestamp)
        && (!('publishedBy' in request.resource.data)
          || request.resource.data.publishedBy == null
          || request.resource.data.publishedBy == request.auth.uid)
        && (!('changeSummary' in request.resource.data)
          || request.resource.data.changeSummary == null
          || request.resource.data.changeSummary is string);
    }

    function validLegalDocumentVersion(documentType, version) {
      return isLegalDocumentType(documentType)
        && request.resource.data.keys().hasOnly(legalDocumentVersionFields())
        && request.resource.data.documentType == documentType
        && request.resource.data.version == version
        && request.resource.data.version is string
        && request.resource.data.versionNumber is int
        && request.resource.data.status in ['draft', 'published', 'archived']
        && request.resource.data.requiresAcceptance is bool
        && request.resource.data.defaultLocale is string
        && request.resource.data.canonicalLocale is string
        && request.resource.data.locales is map
        && request.resource.data.locales.keys().size() > 0
        && request.resource.data.locales[request.resource.data.defaultLocale] is map
        && request.resource.data.locales[request.resource.data.defaultLocale].title is string
        && request.resource.data.locales[request.resource.data.defaultLocale].contentMarkdown is string
        && (!('contentText' in request.resource.data.locales[request.resource.data.defaultLocale])
          || request.resource.data.locales[request.resource.data.defaultLocale].contentText == null
          || request.resource.data.locales[request.resource.data.defaultLocale].contentText is string)
        && (!('contentHash' in request.resource.data.locales[request.resource.data.defaultLocale])
          || request.resource.data.locales[request.resource.data.defaultLocale].contentHash == null
          || request.resource.data.locales[request.resource.data.defaultLocale].contentHash is string)
        && request.resource.data.locales[request.resource.data.canonicalLocale] is map
        && request.resource.data.locales[request.resource.data.canonicalLocale].title is string
        && request.resource.data.locales[request.resource.data.canonicalLocale].contentMarkdown is string
        && (!('contentText' in request.resource.data.locales[request.resource.data.canonicalLocale])
          || request.resource.data.locales[request.resource.data.canonicalLocale].contentText == null
          || request.resource.data.locales[request.resource.data.canonicalLocale].contentText is string)
        && (!('contentHash' in request.resource.data.locales[request.resource.data.canonicalLocale])
          || request.resource.data.locales[request.resource.data.canonicalLocale].contentHash == null
          || request.resource.data.locales[request.resource.data.canonicalLocale].contentHash is string)
        && request.resource.data.contentHash is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid
        && (!('publishedAt' in request.resource.data)
          || request.resource.data.publishedAt == null
          || request.resource.data.publishedAt is timestamp)
        && (!('publishedBy' in request.resource.data)
          || request.resource.data.publishedBy == null
          || request.resource.data.publishedBy == request.auth.uid)
        && (!('changeSummary' in request.resource.data)
          || request.resource.data.changeSummary == null
          || request.resource.data.changeSummary is string)
        && (!('supersedesVersion' in request.resource.data)
          || request.resource.data.supersedesVersion == null
          || request.resource.data.supersedesVersion is string);
    }

    function userSelfDeletionFields() {
      return [
        'accountStatus',
        'blockState',
        'isBlocked',
        'displayName',
        'fullName',
        'bio',
        'city',
        'email',
        'telegramUsername',
        'avatarURL',
        'updatedAt'
      ];
    }

    function recentViewFields() {
      return ['itemId', 'itemType', 'title', 'subtitle', 'imageURL', 'viewedAt'];
    }

    function activityLogFields() {
      return ['id', 'actionType', 'targetId', 'targetType', 'title', 'subtitle', 'imageURL', 'createdAt'];
    }

    function feedbackCreateFields() {
      return [
        'id',
        'userId',
        'userDisplayName',
        'type',
        'subject',
        'message',
        'status',
        'createdAt',
        'updatedAt',
        'lastMessageText',
        'lastMessageAt',
        'lastMessageByUserId',
        'lastMessageByRole',
        'unreadForOwner',
        'unreadForUser'
      ];
    }

    function feedbackOwnerUpdateFields() {
      return [
        'ownerReply',
        'repliedAt',
        'repliedByUserId',
        'status',
        'updatedAt',
        'lastMessageText',
        'lastMessageAt',
        'lastMessageByUserId',
        'lastMessageByRole',
        'unreadForOwner',
        'unreadForUser'
      ];
    }

    function feedbackUserReplyUpdateFields() {
      return [
        'status',
        'updatedAt',
        'lastMessageText',
        'lastMessageAt',
        'lastMessageByUserId',
        'lastMessageByRole',
        'unreadForOwner',
        'unreadForUser'
      ];
    }

    function feedbackChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function feedbackMessageFields() {
      return ['id', 'feedbackId', 'senderId', 'senderDisplayName', 'senderRole', 'text', 'createdAt', 'isSystem'];
    }

    function safeFeedbackCreate(feedbackId) {
      return isActiveUser()
        && request.resource.data.keys().hasOnly(feedbackCreateFields())
        && request.resource.data.id == feedbackId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userDisplayName is string
        && request.resource.data.type in ['question', 'suggestion', 'bug', 'report']
        && (!('subject' in request.resource.data) || request.resource.data.subject is string)
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageText == request.resource.data.message
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessageByUserId == request.auth.uid
        && request.resource.data.lastMessageByRole == 'user'
        && request.resource.data.unreadForOwner == true
        && request.resource.data.unreadForUser == false;
    }

    function safeFeedbackOwnerUpdate() {
      return canManageFeedback()
        && feedbackChangedKeys().hasOnly(feedbackOwnerUpdateFields())
        && request.resource.data.status in ['open', 'answered', 'closed', 'reviewed', 'archived']
        && request.resource.data.updatedAt is timestamp
        && (!feedbackChangedKeys().hasAny(['lastMessageText']) || request.resource.data.lastMessageText is string)
        && (!feedbackChangedKeys().hasAny(['lastMessageAt']) || request.resource.data.lastMessageAt is timestamp)
        && (!feedbackChangedKeys().hasAny(['lastMessageByUserId']) || request.resource.data.lastMessageByUserId == request.auth.uid)
        && (!feedbackChangedKeys().hasAny(['lastMessageByRole']) || request.resource.data.lastMessageByRole == 'owner')
        && (!feedbackChangedKeys().hasAny(['unreadForOwner']) || request.resource.data.unreadForOwner is bool)
        && (!feedbackChangedKeys().hasAny(['unreadForUser']) || request.resource.data.unreadForUser is bool)
        && (!feedbackChangedKeys().hasAny(['ownerReply'])
          || (request.resource.data.ownerReply is string
            && request.resource.data.ownerReply.size() > 0
            && request.resource.data.ownerReply.size() <= 2000))
        && (!feedbackChangedKeys().hasAny(['repliedAt']) || request.resource.data.repliedAt is timestamp)
        && (!feedbackChangedKeys().hasAny(['repliedByUserId']) || request.resource.data.repliedByUserId == request.auth.uid);
    }

    function safeFeedbackUserReplyUpdate() {
      return isActiveUser()
        && resource.data.userId == request.auth.uid
        && resource.data.status != 'closed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(feedbackUserReplyUpdateFields())
        && request.resource.data.status == 'open'
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageText is string
        && request.resource.data.lastMessageText.size() > 0
        && request.resource.data.lastMessageText.size() <= 2000
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessageByUserId == request.auth.uid
        && request.resource.data.lastMessageByRole == 'user'
        && request.resource.data.unreadForOwner == true
        && request.resource.data.unreadForUser == false;
    }

    function canReadFeedback(feedbackId) {
      return canManageFeedback()
        || (isSignedIn()
          && get(/databases/$(database)/documents/feedback/$(feedbackId)).data.userId == request.auth.uid);
    }

    function safeFeedbackMessageCreate(feedbackId, messageId) {
      let parent = get(/databases/$(database)/documents/feedback/$(feedbackId)).data;
      // TODO: Enforce message creation and parent summary updates as one logical
      // operation with getAfter() or a server-side function in a later pass.
      return isActiveUser()
        && parent.status != 'closed'
        && request.resource.data.keys().hasOnly(feedbackMessageFields())
        && request.resource.data.id == messageId
        && request.resource.data.feedbackId == feedbackId
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.senderDisplayName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.createdAt is timestamp
        && (!('isSystem' in request.resource.data) || request.resource.data.isSystem is bool)
        && (
          (parent.userId == request.auth.uid
            && request.resource.data.senderRole == 'user'
            && (!('isSystem' in request.resource.data) || request.resource.data.isSystem == false))
          || (canManageFeedback() && request.resource.data.senderRole == 'owner')
        );
    }

    function safeRecentViewWrite(uid, recentViewId) {
      return isActiveUser()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(recentViewFields())
        && request.resource.data.itemId is string
        && request.resource.data.itemType in ['news', 'event', 'organization', 'guide']
        && request.resource.data.title is string
        && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string || request.resource.data.subtitle == null)
        && (!('imageURL' in request.resource.data) || request.resource.data.imageURL is string || request.resource.data.imageURL == null)
        && request.resource.data.viewedAt is timestamp
        && recentViewId == request.resource.data.itemType + '_' + request.resource.data.itemId;
    }

    function safeActivityLogWrite(uid, activityLogId) {
      return isActiveUser()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(activityLogFields())
        && request.resource.data.id == activityLogId
        && request.resource.data.actionType in [
          'registeredForEvent',
          'canceledEventRegistration',
          'followedOrganization',
          'unfollowedOrganization',
          'savedNews',
          'unsavedNews',
          'savedEvent',
          'unsavedEvent',
          'savedOrganization',
          'unsavedOrganization'
        ]
        && request.resource.data.targetId is string
        && request.resource.data.targetType in ['news', 'event', 'organization']
        && request.resource.data.title is string
        && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string || request.resource.data.subtitle == null)
        && (!('imageURL' in request.resource.data) || request.resource.data.imageURL is string || request.resource.data.imageURL == null)
        && request.resource.data.createdAt is timestamp;
    }

    function featuredBannerRequiredFields() {
      return [
        'id',
        'imageURL',
        'actionType',
        'regionScope',
        'visibleSections',
        'displayDurationSeconds',
        'priority',
        'isActive',
        'createdAt',
        'updatedAt',
        'createdBy'
      ];
    }

    function featuredBannerAllowedFields() {
      return [
        'id',
        'internalName',
        'title',
        'subtitle',
        'imageURL',
        'actionType',
        'actionTargetID',
        'externalURL',
        'regionScope',
        'federalState',
        'visibleSections',
        'displayDurationSeconds',
        'priority',
        'isActive',
        'startsAt',
        'endsAt',
        'createdAt',
        'updatedAt',
        'createdBy',
        'updatedBy'
      ];
    }

    function featuredBannerActionTypes() {
      return [
        'none',
        'news',
        'event',
        'organization',
        'guide',
        'externalURL'
      ];
    }

    function featuredBannerTargetActionTypes() {
      return ['news', 'event', 'organization', 'guide'];
    }

    function featuredBannerExternalActionTypes() {
      return ['externalURL'];
    }

    function featuredBannerRegionScopes() {
      return ['allAustria', 'federalState'];
    }

    function featuredBannerVisibleSections() {
      return ['home', 'events', 'organizations', 'guide'];
    }

    function featuredBannerHasValidSections(data) {
      return data.visibleSections is list
        && data.visibleSections.size() > 0
        && data.visibleSections.hasOnly(featuredBannerVisibleSections());
    }

    function featuredBannerHasValidActionPayload(data) {
      return (
          !(data.actionType in featuredBannerTargetActionTypes())
          || (
            ('actionTargetID' in data)
            && data.actionTargetID is string
            && data.actionTargetID.size() > 0
          )
        )
        && (
          !(data.actionType in featuredBannerExternalActionTypes())
          || (
            ('externalURL' in data)
            && data.externalURL is string
            && data.externalURL.size() > 0
          )
        );
    }

    function featuredBannerHasValidRegion(data) {
      return data.regionScope in featuredBannerRegionScopes()
        && (
          data.regionScope == 'allAustria'
          || (
            ('federalState' in data)
            && data.federalState is string
            && data.federalState.size() > 0
          )
        );
    }

    function featuredBannerStructurallyValid(data, bannerId) {
      return data.keys().hasAll(featuredBannerRequiredFields())
        && data.keys().hasOnly(featuredBannerAllowedFields())
        && data.id == bannerId
        && data.id is string
        && (!('internalName' in data) || data.internalName == null || data.internalName is string)
        && (!('title' in data) || data.title == null || data.title is string)
        && data.imageURL is string
        && data.imageURL.size() > 0
        && data.actionType in featuredBannerActionTypes()
        && featuredBannerHasValidActionPayload(data)
        && featuredBannerHasValidRegion(data)
        && featuredBannerHasValidSections(data)
        && data.displayDurationSeconds is int
        && data.displayDurationSeconds >= 3
        && data.displayDurationSeconds <= 12
        && data.priority is int
        && data.priority >= 0
        && data.priority <= 1000
        && data.isActive is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.createdBy is string
        && data.createdBy.size() > 0
        && (!('updatedBy' in data) || data.updatedBy == null || data.updatedBy is string)
        && (!('subtitle' in data) || data.subtitle == null || data.subtitle is string)
        && (!('actionTargetID' in data) || data.actionTargetID == null || data.actionTargetID is string)
        && (!('externalURL' in data) || data.externalURL == null || data.externalURL is string)
        && (!('federalState' in data) || data.federalState == null || data.federalState is string)
        && (!('startsAt' in data) || data.startsAt == null || data.startsAt is timestamp)
        && (!('endsAt' in data) || data.endsAt == null || data.endsAt is timestamp);
    }

    function validFeaturedBannerCreate(bannerId) {
      return isActiveUser()
        && canManageFeaturedBanners()
        && featuredBannerStructurallyValid(request.resource.data, bannerId)
        && request.resource.data.createdBy == request.auth.uid
        && (
          !('updatedBy' in request.resource.data)
          || request.resource.data.updatedBy == null
          || request.resource.data.updatedBy == request.auth.uid
        );
    }

    function featuredBannerIdentityFieldsArePreserved(bannerId) {
      return request.resource.data.id == resource.data.id
        && request.resource.data.id == bannerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    function validFeaturedBannerUpdate(bannerId) {
      return isActiveUser()
        && canManageFeaturedBanners()
        && featuredBannerStructurallyValid(request.resource.data, bannerId)
        && featuredBannerIdentityFieldsArePreserved(bannerId)
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function validFeaturedBannerLifecycleUpdate(bannerId) {
      return isActiveUser()
        && canManageFeaturedBanners()
        && resource.data.id == bannerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isActive',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid
        && featuredBannerIdentityFieldsArePreserved(bannerId);
    }

    function canReadFeaturedBanner(bannerId) {
      return resource.data.isActive == true;
    }

    function safeUserCreate(uid) {
      return isSelf(uid)
        && request.resource.data.id == uid
        && request.resource.data.fullName is string
        && request.resource.data.displayName is string
        && request.resource.data.city is string
        && request.resource.data.email is string
        && request.resource.data.bio is string
        && !('role' in request.resource.data)
        && !('moderatorSections' in request.resource.data)
        && request.resource.data.isBlocked == false
        && request.resource.data.blockState == 'active'
        && request.resource.data.globalRole == 'user'
        && request.resource.data.canManageGuide == false
        && request.resource.data.selectedFederalState is string
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.warningCount == 0
        && request.resource.data.acceptedTermsAt is timestamp
        && request.resource.data.acceptedPrivacyAt is timestamp
        && request.resource.data.acceptedTermsVersion is string
        && request.resource.data.acceptedPrivacyVersion is string
        && request.resource.data.termsVersion is string
        && request.resource.data.privacyVersion is string
        && request.resource.data.communityMemberships is list
        && request.resource.data.communityMemberships.size() == 0;
    }

    function safeSelfUserUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfEditableFields());
    }

    function safeSelfStatusAcknowledgement(uid) {
      return isSelf(uid)
        && request.resource.data.id == resource.data.id
        && ('statusUpdatedAt' in resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['statusAcknowledgedAt'])
        && request.resource.data.statusAcknowledgedAt is timestamp
        && request.resource.data.statusAcknowledgedAt >= resource.data.statusUpdatedAt;
    }

    function safeSelfAccountDeletionUpdate(uid) {
      return isSelf(uid)
        && isActiveUser()
        && request.resource.data.id == resource.data.id
        && ('globalRole' in resource.data)
        && resource.data.globalRole != 'owner'
        && request.resource.data.globalRole == resource.data.globalRole
        && (!('role' in resource.data) || request.resource.data.role == resource.data.role)
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!('communityMemberships' in resource.data) || request.resource.data.communityMemberships == resource.data.communityMemberships)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfDeletionFields())
        && request.resource.data.accountStatus == 'deactivated'
        && request.resource.data.blockState == 'deactivated'
        && request.resource.data.isBlocked == true
        && request.resource.data.displayName == 'Видалений користувач'
        && request.resource.data.fullName == ''
        && request.resource.data.bio == ''
        && request.resource.data.city == ''
        && request.resource.data.email == ''
        && (!('telegramUsername' in request.resource.data) || request.resource.data.telegramUsername == null)
        && (!('avatarURL' in request.resource.data) || request.resource.data.avatarURL == null)
        && request.resource.data.updatedAt is timestamp;
    }

    function ownerUserEditableFields() {
      return ['accountStatus', 'blockState', 'warningCount', 'updatedAt', 'isBlocked', 'banExpiresAt'];
    }

    function safeOwnerUserUpdate(uid) {
      return isOwner()
        && uid != request.auth.uid
        && request.resource.data.id == resource.data.id
        && ('globalRole' in resource.data)
        && resource.data.globalRole != 'owner'
        && request.resource.data.globalRole == resource.data.globalRole
        && (!('role' in resource.data) || request.resource.data.role == resource.data.role)
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!('communityMemberships' in resource.data) || request.resource.data.communityMemberships == resource.data.communityMemberships)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerUserEditableFields());
    }

    function canWriteContent(section) {
      return canModerateSection(section);
    }

    function canModerateAppContent(section) {
      return canModerateSection(section);
    }

    function hasOrganizationRole(organizationId, role) {
      return isActiveUser()
        && organizationId is string
        && (
          (
            role == 'communityOwner'
            && ('ownerId' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.ownerId == request.auth.uid
          )
          || (
            role == 'communityAdmin'
            && ('adminIds' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.adminIds.hasAny([request.auth.uid])
          )
          || (
            role == 'communityModerator'
            && ('moderatorIds' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.moderatorIds.hasAny([request.auth.uid])
          )
        );
    }

    function isOrganizationOwner(organizationId) {
      return hasOrganizationRole(organizationId, 'communityOwner');
    }

    function isOrganizationAdmin(organizationId) {
      return hasOrganizationRole(organizationId, 'communityAdmin');
    }

    function isOrganizationModerator(organizationId) {
      return hasOrganizationRole(organizationId, 'communityModerator');
    }

    function canEditOrganizationContent(organizationId) {
      return isOrganizationOwner(organizationId)
        || isOrganizationAdmin(organizationId)
        || isOrganizationModerator(organizationId);
    }

    function canManageOrganizationPhotos(organizationId) {
      return canUseOrganizationOverride() || canEditOrganizationContent(organizationId);
    }

    function canReadOrganizationByLookup(organizationId) {
      return canUseOrganizationOverride()
        || (exists(/databases/$(database)/documents/organizations/$(organizationId))
        && (
          get(/databases/$(database)/documents/organizations/$(organizationId)).data.moderationStatus == 'approved'
          || canEditOrganizationContent(organizationId)
          || (
            canManageOrganizationRequests()
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.moderationStatus in ['pendingReview', 'needsRevision', 'rejected']
          )
          || (
            isActiveUser()
            && ('submittedByUserId' in get(/databases/$(database)/documents/organizations/$(organizationId)).data)
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.submittedByUserId == request.auth.uid
            && get(/databases/$(database)/documents/organizations/$(organizationId)).data.moderationStatus in ['pendingReview', 'needsRevision', 'rejected']
          )
        ));
    }

    function canReadOrganization(organizationId) {
      return canUseOrganizationOverride()
        || (('moderationStatus' in resource.data) && resource.data.moderationStatus == 'approved')
        || (
          canManageOrganizationRequests()
          && resource.data.moderationStatus in ['pendingReview', 'needsRevision', 'rejected']
        )
        || (
          isActiveUser()
          && ('submittedByUserId' in resource.data)
          && resource.data.submittedByUserId == request.auth.uid
          && resource.data.moderationStatus in ['pendingReview', 'needsRevision', 'rejected']
        )
        || canEditOrganizationContent(organizationId);
    }

    function organizationPhotoFields() {
      return ['id', 'organizationId', 'imageURL', 'caption', 'uploadedBy', 'createdAt', 'updatedAt'];
    }

    function safeOrganizationPhotoCreate(organizationId, photoId) {
      return canManageOrganizationPhotos(organizationId)
        && request.resource.data.keys().hasOnly(organizationPhotoFields())
        && request.resource.data.id == photoId
        && request.resource.data.organizationId == organizationId
        && request.resource.data.imageURL is string
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && (!('caption' in request.resource.data) || request.resource.data.caption is string || request.resource.data.caption == null)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp || request.resource.data.updatedAt == null);
    }

    function canModerateOrganizationContent(organizationId) {
      return isOrganizationOwner(organizationId)
        || isOrganizationAdmin(organizationId)
        || isOrganizationModerator(organizationId);
    }

    function canEditOrganizationInfo(organizationId) {
      return canUseOrganizationOverride() || isOrganizationOwner(organizationId) || isOrganizationAdmin(organizationId);
    }

