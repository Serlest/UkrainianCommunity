rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function existsUser(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userData(uid) {
      return userDoc(uid).data;
    }

    function currentUserData() {
      return userData(request.auth.uid);
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwner() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && currentUserData().globalRole == 'owner';
    }

    function isTopAdmin() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && currentUserData().globalRole == 'topAdmin';
    }

    function isAppModerator() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && currentUserData().globalRole == 'appModerator';
    }

    function isActiveUser() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && (
          !('accountStatus' in currentUserData())
          || currentUserData().accountStatus == 'active'
          || currentUserData().accountStatus == 'warned'
        );
    }

    function moderatorSections() {
      return isAppModerator() && ('moderatorSections' in currentUserData())
        ? currentUserData().moderatorSections
        : [];
    }

    function canModerateSection(section) {
      return isOwner()
        || isTopAdmin()
        || (isAppModerator() && moderatorSections().hasAny([section]));
    }

    function isApprovedContent() {
      return resource.data.moderationStatus == 'approved';
    }

    function userSelfEditableFields() {
      return ['fullName', 'displayName', 'telegramUsername', 'city', 'bio', 'email', 'selectedFederalState', 'updatedAt'];
    }

    function safeUserCreate(uid) {
      return isSelf(uid)
        && request.resource.data.id == uid
        && request.resource.data.fullName is string
        && request.resource.data.displayName is string
        && request.resource.data.city is string
        && request.resource.data.email is string
        && request.resource.data.bio is string
        && request.resource.data.role == 'user'
        && request.resource.data.isBlocked == false
        && request.resource.data.blockState == 'active'
        && request.resource.data.globalRole == 'user'
        && request.resource.data.selectedFederalState is string
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.warningCount == 0
        && request.resource.data.acceptedTermsAt is timestamp
        && request.resource.data.acceptedPrivacyAt is timestamp
        && request.resource.data.termsVersion is string
        && request.resource.data.privacyVersion is string
        && request.resource.data.moderatorSections is list
        && request.resource.data.moderatorSections.size() == 0
        && request.resource.data.communityMemberships is list
        && request.resource.data.communityMemberships.size() == 0;
    }

    function safeSelfUserUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfEditableFields());
    }

    function targetUserIsOwner() {
      return resource.data.role == 'owner'
        || ('globalRole' in resource.data && resource.data.globalRole == 'owner');
    }

    function incomingUserBecomesOwner() {
      return request.resource.data.role == 'owner'
        || ('globalRole' in request.resource.data && request.resource.data.globalRole == 'owner');
    }

    function incomingUserBecomesPermanentlyBanned() {
      return ('accountStatus' in request.resource.data)
        && request.resource.data.accountStatus == 'permanentlyBanned';
    }

    function topAdminUserUpdateAllowed() {
      return !targetUserIsOwner()
        && !incomingUserBecomesOwner()
        && !incomingUserBecomesPermanentlyBanned()
        && request.resource.data.id == resource.data.id;
    }

    function canWriteContent(section) {
      return canModerateSection(section);
    }

    function canReadModerationQueue(section) {
      return canModerateSection(section);
    }

    function onlyLikeCountChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']);
    }

    function onlyNewsLikeCountChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']);
    }

    function onlyEventCountersChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'registeredCount']);
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isOwner() || isTopAdmin();

      allow create: if safeUserCreate(uid);

      allow update: if isOwner()
        || (isTopAdmin() && topAdminUserUpdateAllowed())
        || safeSelfUserUpdate(uid);

      allow delete: if isOwner() && uid != request.auth.uid;
    }

    match /news/{newsId} {
      allow read: if isApprovedContent() || canReadModerationQueue('news');
      allow create, delete: if canWriteContent('news');
      allow update: if canWriteContent('news')
        || (isActiveUser() && onlyNewsLikeCountChanged());
    }

    match /events/{eventId} {
      allow read: if isApprovedContent() || canReadModerationQueue('events');
      allow create, delete: if canWriteContent('events');
      allow update: if canWriteContent('events')
        || (isActiveUser() && onlyEventCountersChanged());
    }

    match /organizations/{organizationId} {
      allow read: if isApprovedContent() || canReadModerationQueue('organizations');
      allow create, delete: if canWriteContent('organizations');
      allow update: if canWriteContent('organizations')
        || (isActiveUser() && onlyLikeCountChanged());
    }

    match /likes/{likeId} {
      allow read: if isActiveUser();

      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;

      allow update: if false;

      allow delete: if isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    match /registrations/{registrationId} {
      allow read: if isActiveUser();

      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;

      allow update: if false;

      allow delete: if isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner()
        || isTopAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open';

      allow update, delete: if isOwner() || isTopAdmin();
    }

    match /guideArticles/{articleId} {
      allow read: if resource.data.moderationStatus == 'approved'
        || isOwner()
        || isTopAdmin()
        || isAppModerator();

      allow create, update, delete: if isOwner()
        || isTopAdmin()
        || isAppModerator();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
