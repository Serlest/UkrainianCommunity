    function requestCountersAreZero(data) {
      return data.subscriberCount == 0
        && data.likeCount == 0
        && data.eventsHeldCount == 0
        && data.volunteersCount == 0
        && data.helpedPeopleCount == 0
        && data.likeState == 'notLiked';
    }

    function requestRolesAreEmpty(data) {
      return data.adminIds is list
        && data.adminIds.size() == 0
        && data.moderatorIds is list
        && data.moderatorIds.size() == 0
        && (!('ownerId' in data) || data.ownerId == null || data.ownerId == '');
    }

    function requestReviewMessageUnchanged() {
      return (
          !('reviewMessage' in resource.data)
          && !('reviewMessage' in request.resource.data)
        )
        || (
          ('reviewMessage' in resource.data)
          && ('reviewMessage' in request.resource.data)
          && request.resource.data.reviewMessage == resource.data.reviewMessage
        );
    }

    function requestRejectionReasonUnchanged() {
      return (
          !('rejectionReason' in resource.data)
          && !('rejectionReason' in request.resource.data)
        )
        || (
          ('rejectionReason' in resource.data)
          && ('rejectionReason' in request.resource.data)
          && request.resource.data.rejectionReason == resource.data.rejectionReason
        );
    }

    function requestReviewFieldsCleared() {
      return (!('reviewMessage' in request.resource.data) || request.resource.data.reviewMessage == null)
        && (!('rejectionReason' in request.resource.data) || request.resource.data.rejectionReason == null);
    }

    function safeRequestReviewFieldsUpdate() {
      return (
          request.resource.data.moderationStatus == resource.data.moderationStatus
          && requestReviewMessageUnchanged()
          && requestRejectionReasonUnchanged()
        )
        || (
          request.resource.data.moderationStatus == 'pendingReview'
          && resource.data.moderationStatus in ['needsRevision', 'rejected']
          && requestReviewFieldsCleared()
        );
    }

    function safeOrganizationRequestCreate(organizationId) {
      return isActiveUser()
        && request.resource.data.keys().hasOnly(organizationRequestCreateFields())
        && request.resource.data.id is string
        && request.resource.data.id == organizationId
        && request.resource.data.name is string
        && request.resource.data.description is string
        && request.resource.data.city is string
        && request.resource.data.moderationStatus == 'pendingReview'
        && request.resource.data.submittedByUserId == request.auth.uid
        && request.resource.data.submittedAt is timestamp
        && requestCountersAreZero(request.resource.data)
        && requestRolesAreEmpty(request.resource.data);
    }

    function safeOrganizationRequestUpdate() {
      return isActiveUser()
        && ('submittedByUserId' in resource.data)
        && resource.data.submittedByUserId == request.auth.uid
        && request.resource.data.submittedByUserId == resource.data.submittedByUserId
        && requestCountersAreZero(resource.data)
        && requestCountersAreZero(request.resource.data)
        && requestRolesAreEmpty(resource.data)
        && requestRolesAreEmpty(request.resource.data)
        && resource.data.moderationStatus in ['pendingReview', 'needsRevision', 'rejected']
        && request.resource.data.moderationStatus in ['pendingReview', resource.data.moderationStatus]
        && safeRequestReviewFieldsUpdate()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(organizationRequestUpdateFields());
    }

    function ownDocumentRead() {
      return isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    function ownLikeDocumentRead(likeId) {
      return isActiveUser()
        && likeId.matches('^.+_' + request.auth.uid + '$');
    }

    function ownDocumentCreate() {
      return isActiveUser()
        && request.resource.data.userId == request.auth.uid;
    }

    function ownDocumentDelete() {
      return isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    function newsLikeFields() {
      return ['id', 'userId', 'newsId', 'createdAt'];
    }

    function eventLikeFields() {
      return ['id', 'userId', 'eventId', 'createdAt'];
    }

    function organizationLikeFields() {
      return ['id', 'userId', 'organizationId', 'createdAt'];
    }

    function organizationSubscriptionFields() {
      return ['id', 'userId', 'subscribedOrganizationId', 'createdAt'];
    }

    function validBaseLikeCreate(likeId) {
      return isActiveUser()
        && request.resource.data.id == likeId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt is timestamp;
    }

    function validNewsLikeCreate(likeId) {
      return validBaseLikeCreate(likeId)
        && request.resource.data.keys().hasOnly(newsLikeFields())
        && request.resource.data.newsId is string
        && request.resource.data.newsId.size() > 0
        && likeId == request.resource.data.newsId + '_' + request.auth.uid
        && exists(/databases/$(database)/documents/news/$(request.resource.data.newsId));
    }

    function validEventLikeCreate(likeId) {
      return validBaseLikeCreate(likeId)
        && request.resource.data.keys().hasOnly(eventLikeFields())
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && likeId == 'event_' + request.resource.data.eventId + '_' + request.auth.uid
        && exists(/databases/$(database)/documents/events/$(request.resource.data.eventId));
    }

    function validOrganizationLikeCreate(likeId) {
      return validBaseLikeCreate(likeId)
        && request.resource.data.keys().hasOnly(organizationLikeFields())
        && request.resource.data.organizationId is string
        && request.resource.data.organizationId.size() > 0
        && likeId == 'organization_' + request.resource.data.organizationId + '_' + request.auth.uid
        && exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId));
    }

    function validOrganizationSubscriptionCreate(likeId) {
      return validBaseLikeCreate(likeId)
        && request.resource.data.keys().hasOnly(organizationSubscriptionFields())
        && request.resource.data.subscribedOrganizationId is string
        && request.resource.data.subscribedOrganizationId.size() > 0
        && likeId == 'organization_follow_' + request.resource.data.subscribedOrganizationId + '_' + request.auth.uid
        && exists(/databases/$(database)/documents/organizations/$(request.resource.data.subscribedOrganizationId));
    }

    function isOrganizationSubscriptionRead() {
      // Query-compatible public read for organization subscriber lists.
      // Strict shape validation stays on create; legacy docs may have extra fields.
      return ('subscribedOrganizationId' in resource.data)
        && resource.data.subscribedOrganizationId is string;
    }

    function validLikeCreate(likeId) {
      return validNewsLikeCreate(likeId)
        || validEventLikeCreate(likeId)
        || validOrganizationLikeCreate(likeId)
        || validOrganizationSubscriptionCreate(likeId);
    }

    function isOrganizationContent(data) {
      return ('sourceType' in data)
        && data.sourceType == 'organization'
        && ('organizationId' in data)
        && data.organizationId is string
        && data.organizationId.size() > 0;
    }

    function canCreateOrganizationContent() {
      // Current policy: organization team members create approved content within their organization.
      return isOrganizationContent(request.resource.data)
        && (canUseOrganizationOverride() || canEditOrganizationContent(request.resource.data.organizationId));
    }

    function canUpdateOrganizationContent() {
      return isOrganizationContent(resource.data)
        && isOrganizationContent(request.resource.data)
        && request.resource.data.sourceType == resource.data.sourceType
        && request.resource.data.organizationId == resource.data.organizationId
        && (canUseOrganizationOverride() || canEditOrganizationContent(resource.data.organizationId));
    }

    function canDeleteOrganizationContent() {
      return isOrganizationContent(resource.data)
        && (canUseOrganizationOverride() || isOrganizationOwner(resource.data.organizationId));
    }

    function canModerateNewsComment(newsId) {
      return canModerateAppContent('news')
        || canModerateSection('comments')
        || (
          get(/databases/$(database)/documents/news/$(newsId)).data.sourceType == 'organization'
          && canModerateOrganizationContent(get(/databases/$(database)/documents/news/$(newsId)).data.organizationId)
        );
    }

    function canModerateEventComment(eventId) {
      return canModerateAppContent('events')
        || canModerateSection('comments')
        || (
          get(/databases/$(database)/documents/events/$(eventId)).data.sourceType == 'organization'
          && canModerateOrganizationContent(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId)
        );
    }

    function canReadManagedEventRegistration() {
      return isActiveUser()
        && ('eventId' in resource.data)
        && resource.data.eventId is string
        && exists(/databases/$(database)/documents/events/$(resource.data.eventId))
        && (
          canModerateAppContent('events')
          || (
            get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.sourceType == 'organization'
            && ('organizationId' in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data)
            && canModerateOrganizationContent(get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId)
          )
        );
    }

    function canModerateOrganizationComment(organizationId) {
      return canUseOrganizationOverride()
        || canModerateSection('comments')
        || canModerateOrganizationContent(organizationId);
    }

    function isAppManagedHeroBannerDocument(bannerId) {
      return bannerId == 'homeBanner'
        || bannerId == 'eventsBanner'
        || bannerId == 'organizationsBanner'
        || bannerId == 'guideBanner';
    }

    function canReadModerationQueue(section) {
      return canModerateSection(section);
    }

    function canReadOrganizationModerationQueue(data) {
      return isOrganizationContent(data)
        && canModerateOrganizationContent(data.organizationId)
        && (
          data.moderationStatus == 'pendingReview'
          || data.moderationStatus == 'rejected'
          || data.moderationStatus == 'archived'
        );
    }

    function onlyModerationStatusChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['moderationStatus']);
    }

    function registrationFields() {
      return ['id', 'eventId', 'userId', 'registeredAt', 'createdAt'];
    }

    function validRegistrationCreate(registrationId) {
      let eventPath = /databases/$(database)/documents/events/$(request.resource.data.eventId);
      return isActiveUser()
        && request.resource.data.keys().hasOnly(registrationFields())
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && request.resource.data.id == registrationId
        && registrationId == 'event_' + request.resource.data.eventId + '_' + request.auth.uid
        && request.resource.data.registeredAt is timestamp
        && request.resource.data.createdAt is timestamp
        && exists(eventPath)
        && get(eventPath).data.moderationStatus == 'approved'
        && get(eventPath).data.startDate is timestamp
        && get(eventPath).data.startDate > request.time;
    }

    function notificationPreferenceFields() {
      return ['notificationsEnabled', 'eventRemindersEnabled', 'reminderLeadMinutes', 'updatedAt'];
    }

    function notificationUserMutableFields() {
      return [
        'isRead',
        'readAt',
        'archivedAt',
        'deletedAt',
        'popupPresentedAt'
      ];
    }

    function validNotificationOptionalTimestamp(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] is timestamp
        || request.resource.data[field] == null;
    }

    function validNotificationUserUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(notificationUserMutableFields())
        && request.resource.data.isRead is bool
        && validNotificationOptionalTimestamp('readAt')
        && validNotificationOptionalTimestamp('archivedAt')
        && validNotificationOptionalTimestamp('deletedAt')
        && validNotificationOptionalTimestamp('popupPresentedAt');
    }

    function validNotificationPreferencesWrite(uid) {
      return isActiveUser()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(notificationPreferenceFields())
        && request.resource.data.notificationsEnabled is bool
        && request.resource.data.eventRemindersEnabled is bool
        && request.resource.data.reminderLeadMinutes is int
        && request.resource.data.reminderLeadMinutes >= 0
        && request.resource.data.reminderLeadMinutes <= 10080
        && request.resource.data.updatedAt is timestamp;
    }

    function validPublicProfileWrite(uid) {
      return request.resource.data.keys().hasOnly([
          'id',
          'displayName',
          'avatarURL',
          'city',
          'federalState',
          'updatedAt'
        ])
        && request.resource.data.id == uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.city is string
        && request.resource.data.updatedAt is timestamp
        && (!('avatarURL' in request.resource.data) || request.resource.data.avatarURL is string)
        && (!('federalState' in request.resource.data) || request.resource.data.federalState is string);
    }

    match /publicProfiles/{uid} {
      allow read: if true;

      allow create, update: if (isActiveUser() && request.auth.uid == uid && validPublicProfileWrite(uid))
        || (isOwner() && validPublicProfileWrite(uid));

      allow delete: if isOwner() || (isActiveUser() && request.auth.uid == uid);
    }

    match /legalDocuments/{documentType} {
      allow read: if isLegalDocumentType(documentType);

      allow create, update: if isOwner()
        && validLegalDocumentPointer(documentType);

      allow delete: if false;

      match /versions/{version} {
        allow read: if isOwner()
          || (isLegalDocumentType(documentType)
            && resource.data.status == 'published'
            && get(/databases/$(database)/documents/legalDocuments/$(documentType))
              .data.activeVersion == version);

        allow create: if isOwner()
          && validLegalDocumentVersion(documentType, version);

        allow update: if isOwner()
          && resource.data.status != 'published'
          && request.resource.data.documentType == resource.data.documentType
          && request.resource.data.version == resource.data.version
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && validLegalDocumentVersion(documentType, version);

        allow delete: if false;
      }
    }

    match /legalAcceptanceLogs/{logId} {
      allow read: if isOwner() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isOwner();

      allow create: if safeUserCreate(uid);

      allow update: if safeOwnerUserUpdate(uid)
        || safeSelfUserUpdate(uid)
        || safeSelfStatusAcknowledgement(uid)
        || safeSelfAccountDeletionUpdate(uid);

      allow delete: if (isOwner()
          && uid != request.auth.uid
          && ('globalRole' in resource.data)
          && resource.data.globalRole != 'owner')
        || (isSelf(uid)
          && isActiveUser()
          && ('globalRole' in resource.data)
          && resource.data.globalRole != 'owner');

      match /notificationPreferences/{docId} {
        allow read: if isSelf(uid) && docId == 'settings';

        allow create, update: if docId == 'settings'
          && validNotificationPreferencesWrite(uid);

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && docId == 'settings';
      }

      match /notificationInbox/{notificationId} {
        allow read: if isSelf(uid);

        allow create: if false;

        allow update: if validNotificationUserUpdate(uid);

        allow delete: if false;
      }

      match /newsBookmarks/{newsId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == newsId
          && request.resource.data.newsId == newsId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.newsId == newsId
          && resource.data.userId == uid;
      }

      match /eventBookmarks/{eventId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == eventId
          && request.resource.data.eventId == eventId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.eventId == eventId
          && resource.data.userId == uid;
      }

      match /organizationBookmarks/{organizationId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == organizationId
          && request.resource.data.organizationId == organizationId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.organizationId == organizationId
          && resource.data.userId == uid;
      }

      match /guideMaterialBookmarks/{materialId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == materialId
          && request.resource.data.materialId == materialId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid
          && resource.data.materialId == materialId
          && resource.data.userId == uid;
      }

      match /eventViews/{eventId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == eventId
          && request.resource.data.eventId == eventId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid;
      }

      match /newsViews/{newsId} {
        allow read: if isSelf(uid);

        allow create: if isActiveUser()
          && request.auth.uid == uid
          && request.resource.data.id == newsId
          && request.resource.data.newsId == newsId
          && request.resource.data.userId == uid;

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid;
      }

      match /recentViews/{recentViewId} {
        allow read: if isSelf(uid);

        allow create, update: if safeRecentViewWrite(uid, recentViewId);

        allow delete: if isActiveUser()
          && request.auth.uid == uid;
      }

      match /activityLog/{activityLogId} {
        allow read: if isSelf(uid);

        allow create: if safeActivityLogWrite(uid, activityLogId);

        allow update: if false;

        allow delete: if isActiveUser()
          && request.auth.uid == uid;
      }
    }

    match /news/{newsId} {
      allow read: if isApprovedContent()
        || canReadModerationQueue('news')
        || canReadOrganizationModerationQueue(resource.data);
      allow create: if canCreateOrganizationContent();
      allow delete: if canWriteContent('news') || canDeleteOrganizationContent();
      allow update: if canUpdateOrganizationContent()
        || (
          isOrganizationContent(resource.data)
          && canModerateOrganizationContent(resource.data.organizationId)
          && onlyModerationStatusChanged()
        );

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/news/$(newsId)).data.moderationStatus == 'approved'
          || canReadModerationQueue('news');

        allow create: if isActiveUser()
          && request.resource.data.id == commentId
          && request.resource.data.parentType == 'news'
          && request.resource.data.parentId == newsId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt is timestamp
          && request.resource.data.isDeleted == false;

        allow update: if isActiveUser()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.parentType == resource.data.parentType
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'body', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow delete: if (isActiveUser() && resource.data.authorId == request.auth.uid)
          || canModerateNewsComment(newsId);
      }
    }

    match /events/{eventId} {
      allow read: if isApprovedContent()
        || canReadModerationQueue('events')
        || canReadOrganizationModerationQueue(resource.data);
      allow create: if canCreateOrganizationContent();
      allow delete: if canDeleteOrganizationContent();
      allow update: if canUpdateOrganizationContent()
        || (
          isOrganizationContent(resource.data)
          && canModerateOrganizationContent(resource.data.organizationId)
          && onlyModerationStatusChanged()
        );

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/events/$(eventId)).data.moderationStatus == 'approved'
          || canReadModerationQueue('events');

        allow create: if isActiveUser()
          && request.resource.data.id == commentId
          && request.resource.data.parentType == 'event'
          && request.resource.data.parentId == eventId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt is timestamp
          && request.resource.data.isDeleted == false;

        allow update: if isActiveUser()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.parentType == resource.data.parentType
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'body', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow delete: if (isActiveUser() && resource.data.authorId == request.auth.uid)
          || canModerateEventComment(eventId);
      }
    }

    match /organizations/{organizationId} {
      allow read: if canReadOrganization(organizationId);
      allow create: if isOwner() || safeOrganizationRequestCreate(organizationId);
      allow delete: if isOwner();
      allow update: if safeOrganizationInfoUpdate(organizationId)
        || safeOrganizationRequestUpdate();

      match /photos/{photoId} {
        allow read: if canReadOrganizationByLookup(organizationId);
        allow create: if safeOrganizationPhotoCreate(organizationId, photoId);
        allow update: if false;
        allow delete: if canManageOrganizationPhotos(organizationId)
          && resource.data.organizationId == organizationId;
      }

      match /comments/{commentId} {
        allow read: if canReadOrganizationByLookup(organizationId);

        allow create: if isActiveUser()
          && request.resource.data.id == commentId
          && request.resource.data.parentType == 'organization'
          && request.resource.data.parentId == organizationId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt is timestamp
          && request.resource.data.isDeleted == false;

        allow update: if isActiveUser()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.parentType == resource.data.parentType
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'body', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow delete: if (isActiveUser() && resource.data.authorId == request.auth.uid)
          || canModerateOrganizationComment(organizationId);
      }
    }

    match /likes/{likeId} {
      allow read: if ownDocumentRead()
        || ownLikeDocumentRead(likeId)
        || isOrganizationSubscriptionRead()
        || isOwner();

      allow create: if validLikeCreate(likeId);

      allow update: if false;

      allow delete: if ownDocumentDelete()
        || isOwner();
    }

    match /registrations/{registrationId} {
      allow read: if ownDocumentRead()
        || canReadManagedEventRegistration()
        || isOwner();

      allow create: if validRegistrationCreate(registrationId);

      allow update: if false;

      allow delete: if ownDocumentDelete()
        || isOwner();
    }

    match /feedback/{feedbackId} {
      allow read: if canManageFeedback()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if safeFeedbackCreate(feedbackId);

      allow update: if safeFeedbackOwnerUpdate()
        || safeFeedbackUserReplyUpdate();

      allow delete: if isOwner();

      match /messages/{messageId} {
        allow read: if canReadFeedback(feedbackId);

        allow create: if safeFeedbackMessageCreate(feedbackId, messageId);

        allow update, delete: if false;
      }
    }

    match /auditLogs/{auditLogId} {
      allow read: if isOwner();

      allow create: if isOwner()
        && request.resource.data.actionType in [
          'warningIssued',
          'suspended',
          'banned',
          'unblocked',
          'deactivated'
        ]
        && request.resource.data.targetUserId is string
        && request.resource.data.performedBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.reason is string
        && request.resource.data.previousValue is map
        && request.resource.data.newValue is map;

      allow update, delete: if false;
    }

    match /appConfig/{bannerId} {
      allow read: if isAppManagedHeroBannerDocument(bannerId);
      allow create, update, delete: if isAppManagedHeroBannerDocument(bannerId)
        && canManageFeaturedBanners();
    }

    match /featuredBanners/{bannerId} {
      allow read: if canManageFeaturedBanners() || canReadFeaturedBanner(bannerId);
      allow create: if validFeaturedBannerCreate(bannerId);
      allow update: if validFeaturedBannerUpdate(bannerId)
        || validFeaturedBannerLifecycleUpdate(bannerId);
      allow delete: if isActiveUser() && canManageFeaturedBanners();
    }

    match /guideArticles/{articleId} {
      allow read: if (
          resource.data.moderationStatus == 'approved'
          && (('status' in resource.data) && resource.data.status == 'published')
        )
        || canManageGuide();

      allow create: if validGuideArticleCreate(articleId);
      allow update: if validGuideArticleEditUpdate();
      allow delete: if canManageGuide()
        && guideArticleIsEditableManagedContent();
    }

    match /guideNodes/{nodeId} {
      allow read: if isPublishedGuideV2Resource() || canManageGuide();
      allow create: if validGuideNodeWrite(nodeId);
      allow update: if validGuideNodeWrite(nodeId);
      allow delete: if canManageGuide();
    }

    match /guideMaterials/{materialId} {
      allow read: if isPublishedGuideV2Resource() || canManageGuide();
      allow create: if validGuideMaterialWrite(materialId);
      allow update: if validGuideMaterialWrite(materialId);
      allow delete: if canManageGuide();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
