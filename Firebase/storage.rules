rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function existsUser(uid) {
      return firestore.exists(/databases/(default)/documents/users/$(uid));
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function userData(uid) {
      return userDoc(uid).data;
    }

    function currentUserData() {
      return userData(request.auth.uid);
    }

    function isOwner() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && (
          (('globalRole' in currentUserData()) && currentUserData().globalRole == 'owner')
          || (('role' in currentUserData()) && currentUserData().role == 'owner')
        );
    }

    function isTopAdmin() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && (
          (('globalRole' in currentUserData()) && currentUserData().globalRole == 'topAdmin')
          || (('role' in currentUserData()) && currentUserData().role == 'admin')
        );
    }

    function isAppModerator() {
      return isSignedIn()
        && existsUser(request.auth.uid)
        && (
          (('globalRole' in currentUserData()) && currentUserData().globalRole == 'appModerator')
          || (('role' in currentUserData()) && currentUserData().role == 'moderator')
        );
    }

    function canManageContentImages() {
      return isOwner() || isTopAdmin() || isAppModerator();
    }

    function isAppManagedHeroBannerPath(bannerId, fileName) {
      return (
          bannerId == 'homeBanner'
          || bannerId == 'eventsBanner'
          || bannerId == 'organizationsBanner'
          || bannerId == 'guideBanner'
        )
        && fileName == 'banner.jpg';
    }

    match /news/{filePath=**} {
      allow read: if true;
      allow write: if canManageContentImages();
    }

    match /events/{filePath=**} {
      allow read: if true;
      allow write: if canManageContentImages();
    }

    match /organizations/{filePath=**} {
      allow read: if true;
      allow write: if canManageContentImages();
    }

    match /profileImages/{uid}/{filePath=**} {
      allow read: if true;
      allow write: if isSelf(uid) || isOwner() || isTopAdmin();
    }

    match /appConfig/{bannerId}/{fileName} {
      allow read: if isAppManagedHeroBannerPath(bannerId, fileName) && isSignedIn();
      allow write: if isAppManagedHeroBannerPath(bannerId, fileName)
        && (isOwner() || isTopAdmin());
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
