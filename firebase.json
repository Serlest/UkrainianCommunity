{
  "firestore": {
    "rules": "Firebase/firestore.rules",
    "indexes": "Firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "Firebase/storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  }
}
