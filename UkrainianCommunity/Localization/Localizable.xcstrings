    },
    "legal.terms.content.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Von Nutzerinnen und Nutzern eingereichte Inhalte können überprüft, eingeschränkt oder entfernt werden, wenn sie irreführend, unsicher, rechtswidrig, beleidigend, diskriminierend, spamartig oder thematisch unpassend sind. Rollen mit Moderationsaufgaben dürfen Inhalte gemäß dem Moderationsmodell des Projekts verwalten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Користувацький вміст може бути перевірений, обмежений або видалений, якщо він є оманливим, небезпечним, незаконним, образливим, дискримінаційним, схожим на спам або не відповідає призначенню застосунку. Ролі з модераторськими обов’язками можуть керувати вмістом відповідно до моделі модерації проєкту."
          }
        }
      }
    },
    "legal.terms.content.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Community-Inhalte und Moderation"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вміст спільноти та модерація"
          }
        }
      }
    },
    "legal.terms.intro.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukrainian Community Tirol hilft Menschen dabei, öffentliche Updates, Veranstaltungen, Organisationen und praktische Orientierung zu finden. Wenn Sie die App mit einem Konto verwenden, stimmen Sie zu, sie rechtmäßig, respektvoll und nur für ihren vorgesehenen Community-Zweck zu nutzen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukrainian Community Tirol допомагає знаходити публічні оновлення, події, організації та практичну корисну інформацію. Використовуючи застосунок з обліковим записом, ви погоджуєтеся користуватися ним законно, з повагою та лише для його спільнотної мети."
          }
        }
      }
    },
    "legal.terms.intro.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutzung der App"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Використання застосунку"
          }
        }
      }
    },
    "legal.terms.liability.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die App soll Orientierung und Community-Koordination unterstützen. Sie ersetzt keine rechtliche, medizinische, finanzielle oder behördliche Beratung. Nutzerinnen und Nutzer bleiben für Entscheidungen verantwortlich, die sie auf Grundlage geteilter Informationen treffen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застосунок призначений для орієнтації та координації в межах спільноти. Він не замінює юридичну, медичну, фінансову чи офіційну державну консультацію. Користувачі самі відповідають за рішення, які ухвалюють на основі поширеної інформації."
          }
        }
      }
    },
