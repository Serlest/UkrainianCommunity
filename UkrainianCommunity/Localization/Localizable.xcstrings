    "mock.news.1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ab dieser Woche stehen ehrenamtliche Berater jeden Donnerstagabend in Innsbruck zur Verfugung. Das Format ist offen und richtet sich an ukrainische Familien, die Orientierung in alltaglichen Rechtsfragen brauchen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Від цього тижня волонтери-консультанти будуть доступні щочетверга ввечері в Інсбруку. Формат відкритий і створений для українських родин, яким потрібна орієнтація в повсякденних юридичних питаннях."
          }
        }
      }
    },
    "mock.news.1.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kostenlose Beratungen zu Aufenthalt, Arbeit und Familienfragen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безкоштовні консультації щодо проживання, роботи та сімейних питань."
          }
        }
      }
    },
    "mock.news.1.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gemeinschaftszentrum startet wochentliche Rechtsberatung"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Громадський центр відкриває щотижневі години юридичної підтримки"
          }
        }
      }
    },
    "mock.news.2.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der aktualisierte Leitfaden enthalt Schritte zur Anmeldung, Optionen der Sprachunterstutzung und Links zu lokalen Beratungsstellen. Er ist als erster Orientierungspunkt gedacht, bevor man direkt die Schulverwaltung kontaktiert."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оновлений гід містить кроки реєстрації, варіанти мовної підтримки та посилання на місцеві консультаційні служби. Він задуманий як перша точка орієнтації перед безпосереднім зверненням до адміністрації школи."
          }
        }
      }
    },
