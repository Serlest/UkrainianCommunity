      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praktischer Uberblick zur Primar- und Sekundarschule in Tirol."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Практичний огляд початкової та середньої освіти в Тіролі."
          }
        }
      }
    },
    "mock.news.2.title" : {
