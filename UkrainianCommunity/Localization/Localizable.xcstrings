        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Abend fur Netzwerken, Ankundigungen und praktische Orientierung fur Familien in Tirol. Tee, Kinderbereich und sprachliche Unterstutzung sind verfugbar."
          }
        },
        "uk" : {
